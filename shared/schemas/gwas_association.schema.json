{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lyncht248/dementia-gap-map/shared/schemas/gwas_association.schema.json",
  "title": "GWAS Association",
  "type": "object",
  "required": ["association_id", "study_accession", "trait"],
  "properties": {
    "association_id": {
      "type": "string"
    },
    "study_accession": {
      "type": "string"
    },
    "trait": {
      "type": "string"
    },
    "pmid": {
      "type": ["string", "null"]
    },
    "publication": {
      "type": "object",
      "properties": {
        "title": { "type": ["string", "null"] },
        "journal": { "type": ["string", "null"] },
        "date": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "variant": {
      "type": "object",
      "properties": {
        "rsid": { "type": ["string", "null"] },
        "risk_allele": { "type": ["string", "null"] },
        "chromosome": { "type": ["string", "null"] },
        "position": { "type": ["integer", "null"] }
      },
      "additionalProperties": true
    },
    "reported_genes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "p_value": {
      "type": ["number", "null"]
    },
    "effect": {
      "type": "object",
      "properties": {
        "odds_ratio": { "type": ["number", "null"] },
        "beta": { "type": ["number", "null"] },
        "direction": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
