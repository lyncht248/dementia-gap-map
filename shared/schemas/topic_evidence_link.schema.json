{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lyncht248/dementia-gap-map/shared/schemas/topic_evidence_link.schema.json",
  "title": "Topic Evidence Link",
  "type": "object",
  "required": ["topic_id", "evidence_type", "evidence_id", "link_type"],
  "properties": {
    "topic_id": {
      "type": "string"
    },
    "evidence_type": {
      "type": "string",
      "enum": ["gwas_association", "gene", "pathway", "target", "trial", "disease"]
    },
    "evidence_id": {
      "type": "string"
    },
    "link_type": {
      "type": "string",
      "enum": ["paper_overlap", "gene_mention", "pathway_mapping", "manual_mapping", "model_inference", "mesh_annotation", "chemical_annotation"]
    },
    "supporting_paper_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "score": {
      "type": ["number", "null"]
    },
    "method": {
      "type": "string"
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}
